spring.application.name=-1
spring.mvc.view.prefix=/WEB-INF/views/
spring.mvc.view.suffix=.jsp
# =========================================================================
# 2. CẤU HÌNH KẾT NỐI DATABASE XAMPP MYSQL
# =========================================================================
# Đường dẫn kết nối đến database dattour_db bạn vừa tạo trên Navicat
spring.datasource.url=jdbc:mysql://localhost:3306/company?useSSL=false&serverTimezone=UTC&useUnicode=true&characterEncoding=UTF-8

# Tài khoản mặc định của XAMPP (User là root, mật khẩu để trống)
spring.datasource.username=root
spring.datasource.password=
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.show-sql=true

spring.jpa.hibernate.ddl-auto=update

spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQL8Dialect